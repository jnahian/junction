---
import landing from "../../data/landing.json";
import site from "../../data/site.json";
const { menubar } = landing;
---

<div class="menubar">
  <div class="left">
    <b>{site.name}</b>
    {menubar.left.map((item) => <span>{item}</span>)}
  </div>
  <div class="right">
    <span class="status"><img class="mblogo" src="/logo.png" alt={site.name} width="16" height="16">{site.name}</span>
    <span class="sysicons" aria-hidden="true">
      <svg class="battery" viewBox="0 0 28 13" fill="none">
        <rect x=".6" y=".6" width="22" height="11.8" rx="3.2" stroke="currentColor" stroke-width="1.1" opacity=".55"/>
        <rect x="2.4" y="2.4" width="14" height="8.2" rx="1.8" fill="currentColor"/>
        <path d="M24.4 4.4c1.5.5 1.5 3.7 0 4.2V4.4Z" fill="currentColor" opacity=".55"/>
      </svg>
      <svg class="wifi" viewBox="0 0 18 13" fill="none" stroke="currentColor" stroke-linecap="round">
        <path d="M1.4 4.4a11 11 0 0 1 15.2 0" stroke-width="1.5"/>
        <path d="M4.2 7.4a7 7 0 0 1 9.6 0" stroke-width="1.5"/>
        <path d="M6.9 10.3a3.1 3.1 0 0 1 4.2 0" stroke-width="1.5"/>
      </svg>
      <svg class="control-center" viewBox="0 0 16 13" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
        <path d="M1 3.6h14M1 9.4h14"/>
        <circle cx="5.4" cy="3.6" r="1.9" fill="var(--bg)"/>
        <circle cx="10.6" cy="9.4" r="1.9" fill="var(--bg)"/>
      </svg>
    </span>
    <span id="clock">{menubar.clock}</span>
  </div>
</div>

<script>
  import "../../scripts/menubar-clock.js";
</script>
