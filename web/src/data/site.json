{
  "name": "Junction",
  "version": "v0.5.1",
  "tagline": "A rule-based link router for macOS. Junction sits as your default browser and sends every link to the right browser, profile, or native app. Open source, MIT licensed, zero telemetry.",
  "configPath": "~/.config/junction/config.json",
  "brewTap": "brew tap jnahian/junction https://github.com/jnahian/junction",
  "brewTrust": "brew trust --cask jnahian/junction/junction",
  "brewInstall": "brew install --cask junction",
  "quarantine": "xattr -dr com.apple.quarantine /Applications/Junction.app",
  "github": "https://github.com/jnahian/junction",
  "releases": "https://github.com/jnahian/junction/releases",
  "latestRelease": "https://github.com/jnahian/junction/releases/latest",
