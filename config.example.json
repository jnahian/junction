{
  // Junction accepts comments and trailing commas when reading.
  // The GUI writes back strict, pretty-printed JSON with sorted keys.
  "version": 1,
  "fallback": { "app": "com.apple.Safari" },
  "stripTrackingParams": true,
  // Automatic deep-link rewriters are OFF by default — opt in by ID.
  // (Rules with a "deepLink" action always work, no opt-in needed.)
  "enabledRewriters": ["zoom", "spotify", "linear"],
  // Your own deep-link apps (Settings → Deep Links → Add App…, or hand-write them here).
  // Same shape as the built-ins; an id matching a built-in replaces it. Enable above.
  "customRewriters": [
    {
      "id": "linear",
      "name": "Linear",
      "patterns": ["^https?://linear\\.app/(.*)$"],
      "template": "linear://$1",
      "scheme": "linear"
    },
  ],
  // Slack deep links need a team ID, which Slack permalinks don't carry. Map each
  // workspace subdomain to its team ID (find it in app.slack.com/client/TEAM_ID/…).
  // Unmapped workspaces open in the browser.
  "slackTeams": { "acme": "T01ABCDEF" },
  "rules": [
    {
      "name": "Work links → Chrome work profile",
      "match": {
        "patterns": ["*.atlassian.net/*", "app.clickup.com/*", "*.slack.com/*"]
      },
      "action": { "app": "com.google.Chrome", "profile": "Profile 1" }
    },
    {
      "name": "Zoom → native app",
      "match": { "patterns": ["*.zoom.us/j/*", "*.zoom.us/w/*"] },
      "action": { "deepLink": "zoom" }
    },
    {
      "name": "Links from Terminal → Chrome",
      "match": { "sourceApps": ["com.googlecode.iterm2", "com.apple.Terminal"] },
      "action": { "app": "com.google.Chrome" }
    },
    {
      "name": "Meeting links from calendar → picker",
      "match": { "patterns": ["meet.google.com/*"], "sourceApps": ["com.apple.iCal"] },
      "action": { "prompt": true }
    },
  ]
}
