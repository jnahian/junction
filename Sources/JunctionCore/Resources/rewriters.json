{
  "version": 1,
  "rewriters": [
    {
      "id": "zoom",
      "name": "Zoom",
      "patterns": [
        "^https?://(?:[^./]+\\.)?zoom\\.us/[jw]/(\\d+)(?:\\?(?:[^#]*&)?pwd=([^&#]+))?"
      ],
      "template": "zoommtg://zoom.us/join?confno=$1&pwd=$2",
      "scheme": "zoommtg",
      "bundleID": "us.zoom.xos"
    },
    {
      "id": "spotify",
      "name": "Spotify",
      "patterns": [
        "^https?://open\\.spotify\\.com/(track|album|artist|playlist|show|episode)/([A-Za-z0-9]+)"
      ],
      "template": "spotify:$1:$2",
      "scheme": "spotify",
      "bundleID": "com.spotify.client"
    },
    {
      "id": "slack",
      "name": "Slack (message links)",
      "patterns": [
        "^https?://([^./]+)\\.slack\\.com/archives/([A-Z0-9]+)/p(\\d{10})(\\d{6})"
      ],
      "template": "slack://channel?team=&id=$2&message=$3.$4",
      "scheme": "slack",
      "bundleID": "com.tinyspeck.slackmacgap"
    },
    {
      "id": "slack-channel",
      "name": "Slack (channel links)",
      "patterns": [
        "^https?://([^./]+)\\.slack\\.com/archives/([A-Z0-9]+)/?$"
      ],
      "template": "slack://channel?team=&id=$2",
      "scheme": "slack",
      "bundleID": "com.tinyspeck.slackmacgap"
    },
    {
      "id": "figma",
      "name": "Figma",
      "patterns": [
        "^https?://(?:www\\.)?figma\\.com/(?:file|design)/([A-Za-z0-9]+)(/[^?#]*)?"
      ],
      "template": "figma://file/$1$2",
      "scheme": "figma",
      "bundleID": "com.figma.Desktop"
    },
    {
      "id": "notion",
      "name": "Notion",
      "patterns": [
        "^https?://(?:www\\.)?notion\\.so/(.*)$"
      ],
      "template": "notion://www.notion.so/$1",
      "scheme": "notion",
      "bundleID": "notion.id"
    },
    {
      "id": "teams",
      "name": "Microsoft Teams",
      "patterns": [
        "^https?://teams\\.microsoft\\.com/(l/.*)$"
      ],
      "template": "msteams:/$1",
      "scheme": "msteams",
      "bundleID": "com.microsoft.teams2"
    },
    {
      "id": "discord",
      "name": "Discord",
      "patterns": [
        "^https?://(?:www\\.|ptb\\.|canary\\.)?discord\\.com/(channels/.*)$"
      ],
      "template": "discord://-/$1",
      "scheme": "discord",
      "bundleID": "com.hnc.Discord"
    },
    {
      "id": "linear",
      "name": "Linear",
      "patterns": [
        "^https?://linear\\.app/(.*)$"
      ],
      "template": "linear://linear.app/$1",
      "scheme": "linear",
      "bundleID": "com.linear"
    },
    {
      "id": "vscode",
      "name": "VS Code (vscode.dev / github.dev, experimental)",
      "patterns": [
        "^https?://(?:vscode|github)\\.dev/([^?#]*)"
      ],
      "template": "vscode://$1",
      "scheme": "vscode",
      "bundleID": "com.microsoft.VSCode"
    },
    {
      "id": "clickup",
      "name": "ClickUp",
      "patterns": [
        "^https?://app\\.clickup\\.com/t/([^/?#]+)"
      ],
      "template": "clickup://t/$1",
      "scheme": "clickup",
      "bundleID": "com.clickup.desktop-app"
    },
    {
      "id": "github-desktop",
      "name": "GitHub Desktop (open repository)",
      "patterns": [
        "^(https://github\\.com/[^/?#]+/[^/?#]+?)(?:\\.git)?/?(?:[?#].*)?$"
      ],
      "template": "x-github-client://openRepo/$1",
      "scheme": "x-github-client",
      "bundleID": "com.github.GitHubClient"
    },
    {
      "id": "telegram",
      "name": "Telegram",
      "patterns": [
        "^https?://t\\.me/([^/?#+][^/?#]*)$"
      ],
      "template": "tg://resolve?domain=$1",
      "scheme": "tg",
      "bundleID": "ru.keepcoder.Telegram"
    },
    {
      "id": "whatsapp",
      "name": "WhatsApp",
      "patterns": [
        "^https?://wa\\.me/(\\d+)",
        "^https?://api\\.whatsapp\\.com/send/?\\?(?:[^#]*&)?phone=(\\d+)"
      ],
      "template": "whatsapp://send?phone=$1",
      "scheme": "whatsapp",
      "bundleID": "net.whatsapp.WhatsApp"
    },
    {
      "id": "apple-music",
      "name": "Apple Music",
      "patterns": [
        "^https?://music\\.apple\\.com/([^?#]*)"
      ],
      "template": "music://music.apple.com/$1",
      "scheme": "music",
      "bundleID": "com.apple.Music"
    },
    {
      "id": "asana",
      "name": "Asana",
      "patterns": [
        "^https?://app\\.asana\\.com/([^?#]*)"
      ],
      "template": "asana://app.asana.com/$1",
      "scheme": "asana",
      "bundleID": "com.asana.app"
    },
    {
      "id": "todoist",
      "name": "Todoist",
      "patterns": [
        "^https?://(?:app\\.)?todoist\\.com/showTask\\?(?:[^#]*&)?id=(\\d+)",
        "^https?://app\\.todoist\\.com/app/task/(?:.*-)?([A-Za-z0-9]+)$"
      ],
      "template": "todoist://task?id=$1",
      "scheme": "todoist",
      "bundleID": "com.todoist.mac.Todoist"
    }
  ]
}
